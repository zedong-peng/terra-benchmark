{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "success",
    "completion_time_s",
    "extra_support_contacts",
    "recovery_steps",
    "foot_placement_error_mm",
    "energy_proxy"
  ],
  "properties": {
    "success": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "completion_time_s": { "type": "number", "minimum": 0.0 },
    "extra_support_contacts": { "type": "integer", "minimum": 0 },
    "recovery_steps": { "type": "integer", "minimum": 0 },
    "foot_placement_error_mm": { "type": "number", "minimum": 0.0 },
    "energy_proxy": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
  },
  "additionalProperties": false
}
